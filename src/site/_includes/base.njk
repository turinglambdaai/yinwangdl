<!DOCTYPE html>
<html lang="{{ meta.mainLanguage }}">
<head>
  <meta charset="UTF-8">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} - {% endif %}{{ meta.siteName }}</title>
  <meta name="description" content="{% if excerpt %}{{ excerpt }}{% else %}王垠博客文章备份，自动爬取存档{% endif %}">
  <link rel="canonical" href="{{ meta.siteBaseUrl }}{{ page.url }}">
  <meta name="google-adsense-account" content="ca-pub-3215512126020129">
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3215512126020129"
    crossorigin="anonymous"></script>
  <script defer src="https://cloud.umami.is/script.js" data-website-id="38c4a1f4-0780-448e-a6f3-2e614c245585"></script>
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
  <div class="page-layout">
    <aside class="ad-sidebar ad-sidebar--left">
      <ins class="adsbygoogle"
        style="display:block"
        data-ad-client="ca-pub-3215512126020129"
        data-ad-slot="7014497615"
        data-ad-format="auto"
        data-full-width-responsive="true"></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>
    <div class="page-body">
      <header class="site-header">
        <div class="container">
          <div class="site-logo" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 2c1.85 0 3.55.63 4.9 1.69L14.3 8.8a4.97 4.97 0 0 0-4.6 0L7.1 5.69A7.96 7.96 0 0 1 12 4zM4 12c0-1.85.63-3.55 1.69-4.9L8.8 9.7a4.97 4.97 0 0 0 0 4.6l-3.11 2.6A7.96 7.96 0 0 1 4 12zm8 8c-1.85 0-3.55-.63-4.9-1.69l2.6-3.11a4.97 4.97 0 0 0 4.6 0l2.6 3.11A7.96 7.96 0 0 1 12 20zm6.31-3.1L15.2 14.3a4.97 4.97 0 0 0 0-4.6l3.11-2.6A7.96 7.96 0 0 1 20 12c0 1.85-.63 3.55-1.69 4.9z"/></svg>
          </div>
          <h1 class="site-title">{{ meta.siteName }}</h1>
          <p class="site-desc">自动备份 <a href="https://www.yinwang.org">yinwang.org</a> 博客文章 | <a href="https://github.com/jrtxio/yinwangdl">GitHub</a></p>
        </div>
      </header>
      <main class="container">
        {{ content | safe }}
      </main>
      <div class="ad-mobile">
        <ins class="adsbygoogle"
          style="display:block"
          data-ad-client="ca-pub-3215512126020129"
          data-ad-slot="7014497615"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>
      <footer class="site-footer">
        <div class="container">
          <p>内容版权归原作者所有 | 本站仅作备份存档 | <a href="https://cloud.umami.is/share/XoOzcFrnLbRY6EQH" target="_blank" rel="noopener">访问统计</a></p>
        </div>
      </footer>
    </div>
    <aside class="ad-sidebar ad-sidebar--right">
      <ins class="adsbygoogle"
        style="display:block"
        data-ad-client="ca-pub-3215512126020129"
        data-ad-slot="7014497615"
        data-ad-format="auto"
        data-full-width-responsive="true"></ins>
      <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </aside>
  </div>

<div id="search-overlay" class="search-overlay">
  <div class="search-backdrop"></div>
  <div class="search-dialog">
    <div class="search-input-wrap">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="8.5" cy="8.5" r="5.5"/><line x1="13" y1="13" x2="18" y2="18"/></svg>
      <input type="text" id="search-input" placeholder="搜索文章标题…" autocomplete="off">
      <kbd class="search-kbd">Esc</kbd>
    </div>
    <div id="search-results" class="search-results">
      <div class="search-hint">输入关键词开始搜索</div>
    </div>
  </div>
</div>

<button id="search-trigger" class="search-trigger" aria-label="搜索">
  <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="8.5" cy="8.5" r="5.5"/><line x1="13" y1="13" x2="18" y2="18"/></svg>
  <span class="search-trigger-text">搜索</span>
  <span class="search-trigger-tip">Ctrl K</span>
</button>

<script>
(function(){
  var trigger=document.getElementById('search-trigger');
  var overlay=document.getElementById('search-overlay');
  var backdrop=overlay.querySelector('.search-backdrop');
  var input=document.getElementById('search-input');
  var results=document.getElementById('search-results');
  var searchData=null;

  function open(){overlay.classList.add('active');document.body.style.overflow='hidden';input.focus();}
  function close(){overlay.classList.remove('active');document.body.style.overflow='';input.value='';results.innerHTML='<div class="search-hint">输入关键词开始搜索</div>';}

  trigger.addEventListener('click',open);
  backdrop.addEventListener('click',close);

  document.addEventListener('keydown',function(e){
    if((e.metaKey||e.ctrlKey)&&e.key==='k'){e.preventDefault();overlay.classList.contains('active')?close():open();}
    if(e.key==='Escape'&&overlay.classList.contains('active'))close();
  });

  function load(cb){
    if(searchData){cb();return;}
    fetch('/search.json').then(function(r){return r.json();}).then(function(d){searchData=d;cb();}).catch(function(){results.innerHTML='<div class="search-hint">加载失败，请刷新重试</div>';});
  }

  input.addEventListener('input',function(){
    var q=this.value.trim().toLowerCase();
    if(!q){results.innerHTML='<div class="search-hint">输入关键词开始搜索</div>';return;}
    load(function(){
      var matched=searchData.filter(function(p){return p.title.toLowerCase().indexOf(q)!==-1;});
      if(!matched.length){results.innerHTML='<div class="search-hint">没有找到「'+q.replace(/</g,'&lt;')+'」相关的文章</div>';return;}
      var html='';
      matched.slice(0,15).forEach(function(p){
        var t=p.title;
        var idx=t.toLowerCase().indexOf(q);
        if(idx!==-1){t=t.substring(0,idx)+'<mark>'+t.substring(idx,idx+q.length)+'</mark>'+t.substring(idx+q.length);}
        html+='<a href="'+p.url+'" class="search-result-item">'
          +'<span class="search-result-title">'+t+'</span>'
          +'<span class="search-result-date">'+p.date+'</span>'
          +'</a>';
      });
      if(matched.length>15)html+='<div class="search-hint">还有 '+(matched.length-15)+' 篇相关文章</div>';
      results.innerHTML=html;
    });
  });
})();
</script>
</body>
</html>
